                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     The 183rd New York State Legislature , consisting of the [New York State Senate](/New_York_State_Senate) and the [New York State Assembly](/New_York_State_Assembly), met from January 3, 1979, to December 31, 1980, during the fifth and sixth years of [Hugh Carey](/Hugh_Carey)'s [governorship](/Governor_of_New_York), in [Albany](/Albany,_New_York).

### Background

Under the provisions of the [New York Constitution](/New_York_Constitution) of 1938 and the U.S. Supreme Court decision to follow the [One man, one vote](/One_man,_one_vote) rule, re-apportioned in 1971, and amended in 1974, by the legislature, 60 Senators and 150 assemblymen were elected in single-seat districts for two-year terms. Senate and Assembly districts consisted of approximately the same number of inhabitants, the area being apportioned contiguously without restrictions regarding county boundaries.

At this time there were two major political parties: the [Republican Party](/Republican_Party_(United_States)) and the [Democratic Party](/Democratic_Party_(United_States)). The [Conservative Party](/Conservative_Party_of_New_York_State), the [Right to Life Party](/New_York_State_Right_to_Life_Party), the [Liberal Party](/Liberal_Party_of_New_York), the [Libertarian Party](/Libertarian_Party_(United_States)), the [Socialist Workers Party](/Socialist_Workers_Party_(United_States)), the [Communist Party](/Communist_Party_USA) and the [Labor Party](/U.S._Labor_Party) also nominated tickets.

### Elections

The [1978 New York state election](/1978_New_York_gubernatorial_election) was held on November 7. Governor [Hugh Carey](/Hugh_Carey) was re-elected, and Secretary of State [Mario Cuomo](/Mario_Cuomo) was elected Lieutenant Governor, both Democrats. The elections to the other two statewide elective offices resulted in a Republican Comptroller and a Democratic Attorney General. The approximate party strength at this election, as expressed by the vote for Governor, was: Democrats 2,306,000; Republicans 1,913,000; Conservatives 243,000; Right to Life 130,000; Liberals 123,000; Libertarians 19,000; Socialist Workers 13,000; Communists 11,000; and Labor 9,000.

Seven of the ten women members of the previous legislature were elected again: State Senators [Olga A. Méndez](/Olga_A._M%C3%A9ndez) (Dem.), of [East Harlem](/East_Harlem), and [Linda Winikow](/Linda_Winikow) (Dem.), of [Spring Valley, New York](/Spring_Valley,_New_York); and Assemblywomen [Elizabeth Connelly](/Elizabeth_Connelly) (Dem.), of [Staten Island](/Staten_Island); [Pinny Cooke](/Pinny_Cooke) (Rep.), of [Rochester, New York](/Rochester,_New_York); [Estella B. Diggs](/Estella_B._Diggs) (Dem.), of [the Bronx](/The_Bronx); and [Gerdi E. Lipschutz](/Gerdi_E._Lipschutz) (Dem.), of [Queens](/Queens), were re-elected; and Assemblywoman [Mary B. Goodhue](/Mary_B._Goodhue) (Rep.), a lawyer of [Mount Kisco, New York](/Mount_Kisco,_New_York), was elected to the state Senate. [Carol Berman](/Carol_Berman) (Dem.), of [Lawrence, Nassau County, New York](/Lawrence,_Nassau_County,_New_York), was also elected to the state Senate. [Rhoda S. Jacobs](/Rhoda_S._Jacobs) (Dem.), of [Brooklyn](/Brooklyn); [Joan B. Hague](/Joan_B._Hague) (Rep.), of [Glens Falls, New York](/Glens_Falls,_New_York); [May W. Newburger](/May_W._Newburger) (Dem.), of [Great Neck, New York](/Great_Neck,_New_York); [Toni Rettaliata](/Toni_Rettaliata) (Rep.), of [Huntington, New York](/Huntington,_New_York); and [Florence M. Sullivan](/Florence_M._Sullivan) (Rep.), a lawyer of [Brooklyn](/Brooklyn), were also elected to the Assembly. Thus the 183rd Legislature had 13 women members, surpassing the previous record of 11 in the [181st New York State Legislature](/181st_New_York_State_Legislature) (1976).

The [1979 New York state election](/1978_New_York_gubernatorial_election) was held on November 6. No statewide elective offices were up for election, and there were no vacancies in the legislature.

### Sessions

The legislature met for the first regular session (the 202nd) at the State Capitol in [Albany, New York](/Albany,_New_York) on January 3, 1979; &#91;1&#93; and recessed indefinitely in the early morning of June 17. &#91;2&#93;

[Stanley Fink](/Stanley_Fink) (Dem.) was elected [Speaker](/Speaker_of_the_New_York_State_Assembly).

[Warren M. Anderson](/Warren_M._Anderson) (Rep.) was re-elected temporary president of the state Senate.

The legislature was again in session on and off in October and November 1979, to consider legislation concerning energy matters. &#91;3&#93; &#91;4&#93; &#91;5&#93;

The legislature met for the second regular session (the 203rd) at the State Capitol in Albany on January 9, 1980; &#91;6&#93; and recessed indefinitely on June 15. &#91;7&#93;

The legislature met for a special session at the State Capitol in Albany from November 19 &#91;8&#93; to 23. &#91;9&#93; This session was called by Governor Carey to consider legislation on banking, the State budget, and housing in New York City. &#91;10&#93;

