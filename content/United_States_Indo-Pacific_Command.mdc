                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      The United States Indo-Pacific Command ( USINDOPACOM ) is the [unified combatant command](/Unified_combatant_command) of the [United States Armed Forces](/United_States_Armed_Forces) responsible for the [Indo-Pacific region](/Indo-Pacific).

It is the oldest and largest of the unified combatant commands. [Its commander](/Leadership_of_the_United_States_Indo-Pacific_Command), the senior U.S. military officer in the Pacific, is responsible for more than 375,000 service members as well as an area that encompasses more than 100 million square miles (260,000,000 km2), or roughly 52 percent of the Earth's surface, stretching from the waters of the [West Coast of the United States](/West_Coast_of_the_United_States) to the east coast maritime borderline waters of [India](/India) at the meridian 66° longitude east of Greenwich and from the Arctic to the Antarctic. Formerly known as United States Pacific Command (USPACOM), in 2018 the command was renamed to U.S. Indo-Pacific Command in recognition of the increasing connectivity between the [Indian](/Indian_Ocean) and [Pacific](/Pacific_Ocean) oceans.

The Indo-Pacific Command consists of a headquarters organization, five subordinate service component commands ([U.S. Army Pacific](/United_States_Army_Pacific), [U.S. Marine Forces Pacific](/United_States_Marine_Corps_Forces,_Pacific), [U.S. Pacific Fleet](/United_States_Pacific_Fleet), [U.S. Pacific Air Forces](/Pacific_Air_Forces), and [U.S. Space Forces Indo-Pacific](/United_States_Space_Forces_%E2%80%93_Indo-Pacific)), three subordinate unified commands ([U.S. Forces Japan](/United_States_Forces_Japan), [U.S. Forces Korea](/United_States_Forces_Korea)—which includes [Special Operations Command Korea](/Special_Operations_Command_Korea)—and [Special Operations Command Pacific](/Special_Operations_Command_Pacific)), two direct reporting units (U.S. Pacific Command Joint Intelligence Operations Center and the [Center for Excellence in Disaster Management and Humanitarian Assistance](/Center_for_Excellence_in_Disaster_Management_and_Humanitarian_Assistance)), and two standing joint task forces ([Joint Interagency Task Force West](/Joint_Interagency_Task_Force_West)) and Joint Task Force Red Hill. The INDOPACOM headquarters is the Nimitz-MacArthur Pacific Command Center, located on [Camp H. M. Smith](/Camp_H._M._Smith) in Hawaii. |
